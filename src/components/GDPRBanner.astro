---
const { lang = 'en' } = Astro.props;

const content = {
  en: {
    message: "We use cookies to enhance your experience. By continuing to visit this site you agree to our use of cookies.",
    accept: "Accept",
    settings: "Cookie Settings",
    policy: "Privacy Policy"
  },
  es: {
    message: "Utilizamos cookies para mejorar tu experiencia. Al continuar visitando este sitio, aceptas nuestro uso de cookies.",
    accept: "Aceptar",
    settings: "Configuración",
    policy: "Política de Privacidad"
  }
};
---

<div id="gdpr-banner" class="gdpr-banner">
  <p>{content[lang].message}</p>
  <div class="buttons">
    <a href={`/${lang === 'es' ? 'es/' : ''}privacy`} class="policy-link">{content[lang].policy}</a>
    <button id="cookie-settings" class="settings-btn">{content[lang].settings}</button>
    <button id="accept-cookies" class="accept-btn">{content[lang].accept}</button>
  </div>
</div>

<script>
  const banner = document.getElementById('gdpr-banner');
  const acceptBtn = document.getElementById('accept-cookies');
  const settingsBtn = document.getElementById('cookie-settings');

  if (acceptBtn && banner) {
    if (!localStorage.getItem('cookiesAccepted')) {
      banner.style.display = 'flex';
    }

    acceptBtn.addEventListener('click', () => {
      localStorage.setItem('cookiesAccepted', 'true');
      banner.style.display = 'none';
    });
  }

  if (settingsBtn) {
    settingsBtn.addEventListener('click', () => {
      // Open cookie settings modal (to be implemented)
      console.log('Cookie settings clicked');
    });
  }
</script>

<style>
  .gdpr-banner {
    display: none;
    position: fixed;
    bottom: 1rem;
    left: 1rem;
    right: 1rem;
    max-width: 760px;
    margin-inline: auto;
    background: var(--surface);
    color: var(--body);
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    box-shadow: 0 16px 40px rgba(13, 31, 51, 0.18);
    padding: 1.25rem 1.5rem;
    z-index: 1000;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  p {
    margin: 0;
    flex: 1;
    min-width: 260px;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .buttons {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
  }

  button {
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.2;
    padding: 0.55rem 1.25rem;
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease, transform 0.15s ease;
  }

  .accept-btn {
    background: var(--accent);
    color: var(--surface);
    border: 0;
  }

  .accept-btn:hover {
    background: var(--accent-deep);
    transform: translateY(-1px);
  }

  .accept-btn:active {
    transform: scale(0.98);
  }

  .settings-btn {
    background: transparent;
    color: var(--ink);
    border: 1px solid var(--line);
  }

  .settings-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .policy-link {
    color: var(--accent);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 0.25em;
    transition: color 0.2s ease;
  }

  .policy-link:hover {
    color: var(--accent-deep);
  }

  @media (max-width: 768px) {
    .gdpr-banner {
      left: 0.75rem;
      right: 0.75rem;
      bottom: 0.75rem;
      text-align: center;
      padding: 1rem;
    }

    .buttons {
      width: 100%;
      justify-content: center;
    }
  }
</style>
