---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Icon } from 'astro-icon/components';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const title = t('site.title');
const description = t('site.description');
---

<Layout title={title} description={description}>
	<Header currentLang={lang} />
	<main>
		<header class="page-header">
			<h1>{t('contact.title')}</h1>
			<p class="lead">{t('contact.subtitle')}</p>
		</header>
		<div class="contact-content">
			<aside class="contact-info">
				<h2>{t('contact.howToReach')}</h2>
				<p>{t('contact.formInfo')}</p>
				<p>{t('contact.alternativeContact')}</p>
				<ul>
					<li>
						<Icon name="mdi:email-outline" />
						<span>{t('contact.email')}</span>
					</li>
					<li>
						<Icon name="mdi:whatsapp" />
						<span>{t('contact.phone')}</span>
					</li>
					<li>
						<Icon name="mdi:map-marker-outline" />
						<span>{t('contact.address')}</span>
					</li>
				</ul>
			</aside>
			<div class="contact-form">
				<iframe
					src="https://docs.google.com/forms/d/e/1FAIpQLSdqKC_1ExbqUBQ6E-rAIY_mkM1vbP0aX88TffwHps3knapArQ/viewform?embedded=true"
					width="100%"
					title={t('contact.title')}
					loading="lazy"
				>Loading…</iframe>
			</div>
		</div>
	</main>
	<Footer />
</Layout>

<style>
	main {
		width: 100%;
		max-width: 1100px;
		margin: 0 auto;
		padding: clamp(3rem, 6vw, 5rem) 1.5rem 4rem;
		box-sizing: border-box;
	}
	.page-header h1 {
		font-size: clamp(2rem, 4.5vw, 3rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
		color: var(--ink);
		margin: 0 0 0.75rem;
	}
	.page-header .lead {
		font-size: 1.125rem;
		line-height: 1.6;
		color: var(--body);
		max-width: 65ch;
		margin: 0;
	}
	.contact-content {
		display: grid;
		grid-template-columns: 5fr 7fr;
		gap: clamp(1.5rem, 3vw, 2.5rem);
		align-items: start;
		margin-top: clamp(2rem, 4vw, 3rem);
	}
	.contact-info {
		background: var(--surface);
		border: 1px solid var(--line);
		border-radius: var(--radius-card);
		padding: clamp(1.5rem, 3vw, 2rem);
	}
	.contact-info h2 {
		font-size: 1.25rem;
		letter-spacing: -0.01em;
		color: var(--ink);
		margin: 0 0 1rem;
	}
	.contact-info p {
		color: var(--body);
		line-height: 1.6;
		margin: 0 0 1rem;
	}
	.contact-info ul {
		list-style: none;
		margin: 1.25rem 0 0;
		padding: 0;
	}
	.contact-info li {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.7rem 0;
		color: var(--body);
		font-size: 0.95rem;
	}
	.contact-info li + li {
		border-top: 1px solid var(--line);
	}
	.contact-info [data-icon] {
		width: 1.25rem;
		height: 1.25rem;
		flex-shrink: 0;
		color: var(--accent);
	}
	.contact-form iframe {
		display: block;
		width: 100%;
		min-height: 640px;
		border: 0;
		border-radius: var(--radius-input);
		background: var(--surface);
	}
	@media (max-width: 880px) {
		.contact-content {
			grid-template-columns: 1fr;
		}
	}
	@media (prefers-reduced-motion: no-preference) {
		.page-header,
		.contact-info,
		.contact-form {
			animation: rise-in 0.5s ease-out both;
		}
		.contact-info {
			animation-delay: 0.08s;
		}
		.contact-form {
			animation-delay: 0.16s;
		}
		@keyframes rise-in {
			from {
				opacity: 0;
				transform: translateY(10px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}
	}
</style>
