---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Icon } from 'astro-icon/components';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const title = t('site.title');
const description = t('site.description');
---

<Layout title={title} description={description}>
	<Header currentLang={lang} />
	<main>
		<header class="page-header">
			<h1>{t('contact.title')}</h1>
			<p class="lead">{t('contact.subtitle')}</p>
		</header>
		<div class="contact-content">
			<aside class="contact-info">
				<h2>{t('contact.howToReach')}</h2>
				<p>{t('contact.formInfo')}</p>
				<p>{t('contact.alternativeContact')}</p>
				<ul>
					<li>
						<Icon name="mdi:email-outline" />
						<span>{t('contact.email')}</span>
					</li>
					<li>
						<Icon name="mdi:whatsapp" />
						<span>{t('contact.phone')}</span>
					</li>
					<li>
						<Icon name="mdi:map-marker-outline" />
						<span>{t('contact.address')}</span>
					</li>
				</ul>
			</aside>
			<div class="contact-form">
				<form
					id="contact-form"
					method="POST"
					action="https://aunova--fa0f9d9e664211f1acf11607ee4eb77e.web.val.run"
					data-success={t('contact.form.success')}
					data-error={t('contact.form.error')}
					data-sending={t('contact.form.sending')}
				>
					<label>
						<span>{t('contact.form.name')}</span>
						<input type="text" name="name" required maxlength="200" autocomplete="name" />
					</label>
					<label>
						<span>{t('contact.form.email')}</span>
						<input type="email" name="email" required maxlength="200" autocomplete="email" />
					</label>
					<label>
						<span>{t('contact.form.message')}</span>
						<textarea
							name="message"
							required
							rows="7"
							maxlength="5000"
							placeholder={t('contact.form.messagePlaceholder')}></textarea>
					</label>
					<input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" class="hp" />
					<button type="submit">{t('contact.form.submit')}</button>
					<p class="form-status" role="status" aria-live="polite"></p>
				</form>
			</div>
		</div>
	</main>
	<Footer />
</Layout>

<style>
	main {
		width: 100%;
		max-width: 1100px;
		margin: 0 auto;
		padding: clamp(3rem, 6vw, 5rem) 1.5rem 4rem;
		box-sizing: border-box;
	}
	.page-header h1 {
		font-size: clamp(2rem, 4.5vw, 3rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
		color: var(--ink);
		margin: 0 0 0.75rem;
	}
	.page-header .lead {
		font-size: 1.125rem;
		line-height: 1.6;
		color: var(--body);
		max-width: 65ch;
		margin: 0;
	}
	.contact-content {
		display: grid;
		grid-template-columns: 5fr 7fr;
		gap: clamp(1.5rem, 3vw, 2.5rem);
		align-items: start;
		margin-top: clamp(2rem, 4vw, 3rem);
	}
	.contact-info {
		background: var(--surface);
		border: 1px solid var(--line);
		border-radius: var(--radius-card);
		padding: clamp(1.5rem, 3vw, 2rem);
	}
	.contact-info h2 {
		font-size: 1.25rem;
		letter-spacing: -0.01em;
		color: var(--ink);
		margin: 0 0 1rem;
	}
	.contact-info p {
		color: var(--body);
		line-height: 1.6;
		margin: 0 0 1rem;
	}
	.contact-info ul {
		list-style: none;
		margin: 1.25rem 0 0;
		padding: 0;
	}
	.contact-info li {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.7rem 0;
		color: var(--body);
		font-size: 0.95rem;
	}
	.contact-info li + li {
		border-top: 1px solid var(--line);
	}
	.contact-info [data-icon] {
		width: 1.25rem;
		height: 1.25rem;
		flex-shrink: 0;
		color: var(--accent);
	}
	.contact-form form {
		display: flex;
		flex-direction: column;
		gap: 1.1rem;
		background: var(--surface);
		border: 1px solid var(--line);
		border-radius: var(--radius-card);
		padding: clamp(1.5rem, 3vw, 2rem);
	}
	.contact-form label {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}
	.contact-form label span {
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--ink);
	}
	.contact-form input,
	.contact-form textarea {
		font: inherit;
		color: var(--ink);
		background: var(--bg, #fff);
		border: 1px solid var(--line);
		border-radius: var(--radius-input);
		padding: 0.65rem 0.8rem;
	}
	.contact-form input:focus-visible,
	.contact-form textarea:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 1px;
	}
	.contact-form textarea {
		resize: vertical;
	}
	.contact-form .hp {
		position: absolute;
		left: -9999px;
		width: 1px;
		height: 1px;
		opacity: 0;
	}
	.contact-form button {
		font: inherit;
		font-weight: 600;
		color: #fff;
		background: var(--accent);
		border: 0;
		border-radius: var(--radius-input);
		padding: 0.75rem 1.25rem;
		cursor: pointer;
	}
	.contact-form button:disabled {
		opacity: 0.6;
		cursor: wait;
	}
	.form-status {
		margin: 0;
		min-height: 1.5em;
		font-size: 0.95rem;
		color: var(--body);
	}
	.form-status.ok {
		color: var(--accent);
	}
	.form-status.err {
		color: #c0392b;
	}
	@media (max-width: 880px) {
		.contact-content {
			grid-template-columns: 1fr;
		}
	}
	@media (prefers-reduced-motion: no-preference) {
		.page-header,
		.contact-info,
		.contact-form {
			animation: rise-in 0.5s ease-out both;
		}
		.contact-info {
			animation-delay: 0.08s;
		}
		.contact-form {
			animation-delay: 0.16s;
		}
		@keyframes rise-in {
			from {
				opacity: 0;
				transform: translateY(10px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}
	}
</style>

<script>
	const form = document.getElementById('contact-form') as HTMLFormElement;
	const status = form.querySelector('.form-status') as HTMLParagraphElement;
	const button = form.querySelector('button') as HTMLButtonElement;
	const idleLabel = button.textContent;

	form.addEventListener('submit', async (event) => {
		event.preventDefault();
		button.disabled = true;
		button.textContent = form.dataset.sending ?? '…';
		status.className = 'form-status';
		status.textContent = '';
		try {
			const res = await fetch(form.action, {
				method: 'POST',
				body: new URLSearchParams(new FormData(form) as unknown as Record<string, string>),
			});
			const data = await res.json();
			if (!res.ok || !data.ok) throw new Error(data.error ?? res.statusText);
			status.classList.add('ok');
			status.textContent = form.dataset.success ?? 'OK';
			form.reset();
		} catch {
			status.classList.add('err');
			status.textContent = form.dataset.error ?? 'Error';
		} finally {
			button.disabled = false;
			button.textContent = idleLabel;
		}
	});
</script>
