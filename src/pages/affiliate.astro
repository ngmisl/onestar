---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const title = t('affiliate.title');
const description = t('affiliate.description');
---

<Layout title={title} description={description}>
  <Header currentLang={lang} />
  <main>
    <section id="affiliate" class="affiliate">
      <h1>{t('affiliate.title')}</h1>
      <p class="lead">{t('affiliate.description')}</p>
      <h2>{t('affiliate.subheading')}</h2>
      <a class="cta-button" href="#affiliate-form">{t('affiliate.callToAction')}</a>
      <div class="form-wrap" id="affiliate-form">
        <iframe
          src="https://docs.google.com/forms/d/e/1FAIpQLSdqKC_1ExbqUBQ6E-rAIY_mkM1vbP0aX88TffwHps3knapArQ/viewform?embedded=true"
          width="100%"
          title={t('affiliate.title')}
          loading="lazy"
        >Loading…</iframe>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  main {
    width: 100%;
    max-width: 680px;
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5rem) 1.5rem 4rem;
    box-sizing: border-box;
  }
  .affiliate {
    text-align: center;
  }
  .affiliate h1 {
    font-size: clamp(2rem, 4.5vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 1rem;
  }
  .affiliate .lead {
    font-size: clamp(1.2rem, 2.5vw, 1.4rem);
    line-height: 1.45;
    color: var(--ink);
    font-weight: 500;
    margin: 0 auto 0.75rem;
    max-width: 30ch;
  }
  .affiliate h2 {
    font-size: 1.05rem;
    font-weight: 400;
    line-height: 1.6;
    color: var(--body);
    margin: 0 auto 1.75rem;
    max-width: 48ch;
  }
  .form-wrap {
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
  }
  .form-wrap iframe {
    display: block;
    width: 100%;
    min-height: 640px;
    border: 0;
    border-radius: var(--radius-input);
    background: var(--surface);
  }
  @media (prefers-reduced-motion: no-preference) {
    .affiliate > * {
      animation: rise-in 0.5s ease-out both;
    }
    .affiliate .lead {
      animation-delay: 0.06s;
    }
    .affiliate h2 {
      animation-delay: 0.12s;
    }
    .affiliate .cta-button {
      animation-delay: 0.18s;
    }
    .affiliate .form-wrap {
      animation-delay: 0.24s;
    }
    @keyframes rise-in {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  }
</style>
